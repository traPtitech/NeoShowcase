{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "minimumReleaseAge": "7d"
    },
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Go minor & patch dependencies"
    },
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Node.js minor & patch dependencies"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions dependencies"
    }
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "schedule": ["* * 1 * *"],
  "timezone": "Asia/Tokyo"
}
